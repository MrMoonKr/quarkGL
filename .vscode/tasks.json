{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake Build model_render (VS2022 Debug)",
            "type": "shell",
            "command": "cmake --build --preset build-vs2022-debug --target model_render",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "CMake Build selected example (VS2022 Debug)",
            "type": "shell",
            "command": "cmake --build --preset build-vs2022-debug --target ${input:exampleName}",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Build model_render (Debug)",
            "type": "shell",
            "command": "bazel build //model_render:model_render -c dbg",
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Build examples (Debug)",
            "type": "shell",
            "command": "bazel build //examples:all -c dbg",
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Build quarkgl (Debug)",
            "type": "shell",
            "command": "bazel build //quarkgl:all -c dbg",
            "group": {
                "kind": "build",
                "isDefault": false
            }
        }
    ],
    "inputs": [
        {
            "type": "pickString",
            "id": "exampleName",
            "description": "Which example to build?",
            "options": [
                "bloom",
                "compute",
                "deferred",
                "geom_shader",
                "hdr",
                "instancing",
                "normal_map",
                "pbr",
                "post_processing",
                "shadow_map",
                "ssao",
                "model_render"
            ]
        }
    ]
}
